# Root environment reference
# Copy the service-level .env.example files into each service when running locally.
# Do not put real secrets in this file.

# AWS
AWS_REGION=ap-southeast-2
AWS_ACCOUNT_ID=123456789012

# Frontend build-time variables
VITE_COGNITO_USER_POOL_ID=ap-southeast-2_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_AWS_REGION=ap-southeast-2
VITE_API_BASE_URL=http://localhost:8080
# The frontend examples below assume you run services with local PORT overrides.
VITE_STREAMING_SERVICE_URL=http://localhost:4000
VITE_MONEY_SERVICE_URL=http://localhost:5000
VITE_FORECAST_SERVICE_URL=http://localhost:6000
VITE_TOUR_SERVICE_URL=http://localhost:7000

# Cognito/JWT
COGNITO_USER_POOL_ID=ap-southeast-2_XXXXXXXXX
COGNITO_REGION=ap-southeast-2
JWKS_CACHE_TTL_SECONDS=86400

# PostgreSQL/RDS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=currency_exchange
DB_USER=postgres
DB_PASSWORD=change-me

# Exchange rate Redis cache
EXCHANGE_RATE_REDIS_HOST=localhost
EXCHANGE_RATE_REDIS_PORT=6379
EXCHANGE_RATE_REDIS_PASSWORD=
EXCHANGE_RATE_REDIS_SSL=false

# Idempotency Redis cache
IDEMPOTENCY_REDIS_HOST=localhost
IDEMPOTENCY_REDIS_PORT=6379
IDEMPOTENCY_REDIS_PASSWORD=
IDEMPOTENCY_REDIS_SSL=false

# Generic Redis variables used by producer/streaming/dataset services
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# Exchange Rate Producer
EXCHANGE_API_URL=https://api.exchangerate-api.com/v4/latest/VND
EXCHANGE_API_KEY=
EXCHANGE_API_TIMEOUT=10
POLLING_INTERVAL_SECONDS=420
CACHE_TTL_SECONDS=480
SUPPORTED_CURRENCIES=USD,EUR,GBP,JPY,CNY,KRW,THB,SGD,MYR,IDR,PHP,AUD

# Streaming Service
PORT=3001
CORS_ORIGIN=http://localhost:5173
HEARTBEAT_INTERVAL_MS=30000
HEARTBEAT_TIMEOUT_MS=10000
RATE_POLL_INTERVAL_MS=5000

# Money Service
MAX_LOCK_RETRIES=3
CLEANUP_INTERVAL_SECONDS=86400
IDEMPOTENCY_TTL_DAYS=7

# Forecast Service / SageMaker
SAGEMAKER_ENDPOINT_NAME=forecast-endpoint

# Dataset Maker
S3_BUCKET=training-data-bucket-name
S3_PREFIX=training-data
LOOKBACK_HOURS=24

# Tour Service / Producer
S3_TOUR_BUCKET=tour-bucket-name
S3_TOURS_PREFIX=tours
S3_IMAGES_PREFIX=tours/images
PRESIGNED_URL_EXPIRY_SECONDS=3600

# Lambda
DB_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-2:123456789012:secret:nmcnpm/rds_password-example
