# ── External Exchange Rate API ────────────────────────────────────────────────
# URL of the external exchange rate API (base currency: VND)
EXCHANGE_API_URL=https://api.exchangerate-api.com/v4/latest/VND

# API key (optional, depends on provider)
EXCHANGE_API_KEY=

# Request timeout in seconds
EXCHANGE_API_TIMEOUT=10

# ── Redis (ElastiCache) ───────────────────────────────────────────────────────
# ElastiCache primary endpoint hostname
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com

# ElastiCache port (default: 6379)
REDIS_PORT=6379

# Redis database index (default: 0)
REDIS_DB=0

# Redis password (if AUTH is enabled)
REDIS_PASSWORD=

# Enable TLS/SSL for Redis connection (required for ElastiCache in-transit encryption)
REDIS_SSL=true

# ── Polling Configuration ─────────────────────────────────────────────────────
# How often to poll the external API (seconds).
#
# Free plan budget (ExchangeRate-API): 1,500 requests/month
#   420s (7 min) → 1,440 req/week → safe for continuous 1-week demo
#   30s           → 20,160 req/week → requires paid plan ($10/month)
#
# Override with a lower value if using a paid plan.
POLLING_INTERVAL_SECONDS=420

# TTL for each exchange rate key in Redis (seconds).
# Set to POLLING_INTERVAL_SECONDS + 60s buffer to avoid stale-key gaps.
CACHE_TTL_SECONDS=480

# ── Supported Currencies ──────────────────────────────────────────────────────
# Comma-separated list of currency codes to track (all rates are vs VND)
SUPPORTED_CURRENCIES=USD,EUR,GBP,JPY,CNY,KRW,THB,SGD,MYR,IDR,PHP,AUD
