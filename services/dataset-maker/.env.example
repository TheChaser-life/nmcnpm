# ── Redis (Exchange Rate Cache) ───────────────────────────────────────────────
# ElastiCache primary endpoint hostname
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com

# ElastiCache port (default: 6379)
REDIS_PORT=6379

# Redis database index (default: 0)
REDIS_DB=0

# Redis password (if AUTH is enabled)
REDIS_PASSWORD=

# Enable TLS/SSL for Redis connection (required for ElastiCache in-transit encryption)
REDIS_SSL=true

# ── RDS PostgreSQL (User_DB) ──────────────────────────────────────────────────
# RDS instance endpoint
DB_HOST=your-rds-endpoint.rds.amazonaws.com

# PostgreSQL port (default: 5432)
DB_PORT=5432

# Database name
DB_NAME=currency_exchange

# Database user
DB_USER=postgres

# Database password (inject from AWS Secrets Manager in production)
DB_PASSWORD=

# ── S3 (Training Data Bucket) ─────────────────────────────────────────────────
# S3 bucket name for training data (preferred env var name)
S3_TRAINING_BUCKET=your-training-data-bucket

# S3 bucket name for training data (legacy alias — S3_TRAINING_BUCKET takes precedence)
S3_BUCKET=your-training-data-bucket

# S3 key prefix for training data (default: training-data)
S3_PREFIX=training-data

# ── Data Collection ───────────────────────────────────────────────────────────
# Number of hours of transaction history to collect (default: 24)
LOOKBACK_HOURS=24

# ── AWS ───────────────────────────────────────────────────────────────────────
# AWS region for S3 client
AWS_REGION=ap-southeast-1
