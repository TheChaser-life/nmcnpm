# AWS Cognito Configuration
# Copy this file to .env.local and fill in the actual values after deploying infrastructure

# Cognito User Pool ID (format: ap-southeast-2_XXXXXXXXX)
VITE_COGNITO_USER_POOL_ID=ap-southeast-2_XXXXXXXXX

# Cognito App Client ID (from nmcnpm_frontend_client)
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Region
VITE_AWS_REGION=ap-southeast-2

# API Base URL (ALB endpoint or local dev proxy)
VITE_API_BASE_URL=https://your-alb-domain.com

# Money Service base URL (task 6.2)
# In production: ALB domain root URL (e.g. https://your-alb-domain.com)
# In local dev: http://localhost:5000
# Used by moneyService: POST {VITE_MONEY_SERVICE_URL}/exchange, {VITE_MONEY_SERVICE_URL}/topup, GET {VITE_MONEY_SERVICE_URL}/balance
VITE_MONEY_SERVICE_URL=http://localhost:5000

# Streaming Service WebSocket URL (task 4.3.1)
# In production: ALB domain with /stream path prefix (e.g. https://your-alb-domain.com/stream)
# In local dev: http://localhost:4000
VITE_STREAMING_SERVICE_URL=http://localhost:4000

# Forecast Service base URL (task 5.6.3)
# In production: ALB domain root URL (e.g. https://your-alb-domain.com)
# In local dev: http://localhost:6000
# Used by useForecast hook: GET {VITE_FORECAST_SERVICE_URL}/forecast/{currency_code}
VITE_FORECAST_SERVICE_URL=http://localhost:6000

# Tour Service base URL (task 7.3)
# In production: ALB domain root URL (e.g. https://your-alb-domain.com)
# In local dev: http://localhost:7000
# Used by useTours hook: GET {VITE_TOUR_SERVICE_URL}/tours/{currency_code}
VITE_TOUR_SERVICE_URL=http://localhost:7000
