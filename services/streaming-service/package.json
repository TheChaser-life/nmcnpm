{
  "name": "streaming-service",
  "version": "1.0.0",
  "description": "WebSocket streaming service for real-time exchange rate push (Node.js + Socket.IO)",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "ioredis": "5.3.2",
    "socket.io": "4.7.5"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.2",
    "@types/supertest": "6.0.2",
    "jest": "29.7.0",
    "socket.io-client": "4.7.5",
    "supertest": "7.0.0",
    "ts-jest": "29.1.5",
    "tsx": "4.15.6",
    "typescript": "5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
