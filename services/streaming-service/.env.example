# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Redis (Exchange_Rate_Cache — ElastiCache) ─────────────────────────────────
# Required. Set to the ElastiCache primary endpoint in production.
REDIS_HOST=localhost
REDIS_PORT=6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the frontend origin in production (e.g. https://app.example.com).
# '*' is acceptable in development or when the service is behind the ALB.
CORS_ORIGIN=http://localhost:5173

# ── Heartbeat (Requirement 2.3) ───────────────────────────────────────────────
# How often Socket.IO sends a ping to each client (ms). Design: 30 000.
HEARTBEAT_INTERVAL_MS=30000
# How long Socket.IO waits for a pong before closing the connection (ms). Design: 10 000.
HEARTBEAT_TIMEOUT_MS=10000

# ── Rate polling (Requirement 2.2) ────────────────────────────────────────────
# How often the service polls Redis for updated exchange rates (ms).
# Must be ≤ 5000 to satisfy the ≤5s push latency requirement.
RATE_POLL_INTERVAL_MS=5000
