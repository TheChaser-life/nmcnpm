# ── Travelpayouts API ─────────────────────────────────────────────────────────
# API key from Viator Partner Program
# https://docs.viator.com/partner-api/technical/
VIATOR_API_KEY=

# Base URL for Viator Partner API (default: https://api.viator.com/partner)
VIATOR_API_BASE_URL=https://api.viator.com/partner

# Request timeout in seconds (default: 15)
VIATOR_API_TIMEOUT=15

# Maximum number of tours to fetch per currency (default: 10)
MAX_TOURS_PER_CURRENCY=10

# ── S3 (Tour Data Bucket) ─────────────────────────────────────────────────────
# S3 bucket name for tour data and images
S3_TOUR_BUCKET=your-tour-data-bucket

# S3 key prefix for tour JSON files (default: tours)
S3_TOURS_PREFIX=tours

# S3 key prefix for tour images (default: tours/images)
S3_IMAGES_PREFIX=tours/images

# ── Supported Currencies ──────────────────────────────────────────────────────
# Comma-separated list of currency codes to collect tours for
SUPPORTED_CURRENCIES=USD,EUR,GBP,JPY,CNY,KRW,THB,SGD,MYR,IDR,PHP,AUD

# ── Image Download ────────────────────────────────────────────────────────────
# Timeout for downloading individual tour images (seconds)
IMAGE_DOWNLOAD_TIMEOUT=10

# Maximum image size to download (bytes). Default: 5242880 (5 MB)
MAX_IMAGE_SIZE_BYTES=5242880

# ── AWS ───────────────────────────────────────────────────────────────────────
# AWS region for S3 client
AWS_REGION=ap-southeast-1
