# ── Server ────────────────────────────────────────────────────────────────────
# Port the service listens on
PORT=8080

# ── AWS ───────────────────────────────────────────────────────────────────────
# AWS region
AWS_REGION=ap-southeast-1

# ── Cognito JWT Verification ──────────────────────────────────────────────────
# Cognito User Pool ID (e.g., ap-southeast-1_XXXXXXXXX)
COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX

# AWS region where the Cognito User Pool is deployed
COGNITO_REGION=ap-southeast-1

# ── JWKS Cache ────────────────────────────────────────────────────────────────
# How long to cache Cognito JWKS public keys (seconds). Default: 86400 (24h)
JWKS_CACHE_TTL_SECONDS=86400

# ── RDS PostgreSQL (User_DB) ──────────────────────────────────────────────────
# RDS instance endpoint
DB_HOST=your-rds-endpoint.rds.amazonaws.com

# PostgreSQL port (default: 5432)
DB_PORT=5432

# Database name
DB_NAME=currency_exchange

# Database user
DB_USER=postgres

# Database password (inject from AWS Secrets Manager in production)
DB_PASSWORD=

# ── Exchange Rate Cache (Redis) ───────────────────────────────────────────────
# ElastiCache primary endpoint hostname for exchange rate cache
EXCHANGE_RATE_REDIS_HOST=your-exchange-rate-elasticache.cache.amazonaws.com

# ElastiCache port (default: 6379)
EXCHANGE_RATE_REDIS_PORT=6379

# Redis password (if AUTH is enabled)
EXCHANGE_RATE_REDIS_PASSWORD=

# Enable TLS/SSL for Redis connection
EXCHANGE_RATE_REDIS_SSL=true

# ── Idempotency Cache (Redis) ─────────────────────────────────────────────────
# ElastiCache primary endpoint hostname for idempotency cache (noeviction)
IDEMPOTENCY_REDIS_HOST=your-idempotency-elasticache.cache.amazonaws.com

# ElastiCache port (default: 6379)
IDEMPOTENCY_REDIS_PORT=6379

# Redis password (if AUTH is enabled)
IDEMPOTENCY_REDIS_PASSWORD=

# Enable TLS/SSL for Redis connection
IDEMPOTENCY_REDIS_SSL=true

# ── Transaction Settings ──────────────────────────────────────────────────────
# Maximum number of optimistic lock retries before returning HTTP 409
MAX_LOCK_RETRIES=3

# ── Idempotency Cleanup Job ───────────────────────────────────────────────────
# How often the background cleanup job runs (seconds). Default: 86400 (24h)
CLEANUP_INTERVAL_SECONDS=86400

# Age threshold for removing idempotency keys (days). Default: 7
IDEMPOTENCY_TTL_DAYS=7
